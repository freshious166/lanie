{
  "name": "lanie-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=apps/web-dashboard",
    "start:backend": "npm run start:dev --workspace=apps/backend-api",
    "start:dashboard": "npm run dev --workspace=apps/web-dashboard",
    "start:admin": "npm run dev --workspace=apps/admin-console",
    "start:mobile": "npm run start --workspace=apps/mobile"
  },
  "overrides": {
    "rollup": "npm:@rollup/wasm-node"
  }
}
